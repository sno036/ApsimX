                        {
                          "$type": "Models.Manager, Models",
                          "Code": "\r\nusing APSIM.Shared.Utilities;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\n        \r\n        namespace Models\r\n        {\r\n           [Serializable] \r\n           [System.Xml.Serialization.XmlInclude(typeof(Model))]\r\n            public class Script : Model\r\n            {      \r\n               [Link] Plant Soybean;\r\n               [Link] Clock Clock;\r\n\r\n               [Description(\"Spacing (mm) between rows\")]\r\n               public double RowSpacing { get; set; }\r\n               [Description(\"Depth (mm) Grains are planted\")]\r\n               public double SowingDepth { get; set; }\r\n               [Description(\"Seeds sown (/m2)\")]\r\n               public double SowingRate { get; set; }\r\n               [Description(\"Cultivar\")]\r\n               [Display(Type=DisplayType.CultivarName)]\r\n               public string CultivarName { get; set; }\r\n               [Description(\"Sowing Date\")]\r\n               public DateTime SowingDate { get; set; }\r\n\r\n               [EventSubscribe(\"DoManagement\")]\r\n               private void OnDoManagement(object sender, EventArgs e)\r\n               {\r\n                if (Clock.Today.Date == SowingDate)\r\n                    Soybean.Sow(population:SowingRate, cultivar:CultivarName, depth:SowingDepth, rowSpacing:RowSpacing, budNumber:1);\r\n               }\r\n            }\r\n        }\r\n                \r\n",
                          "Parameters": [
                            {
                              "Key": "RowSpacing",
                              "Value": "760"
                            },
                            {
                              "Key": "SowingDepth",
                              "Value": "50"
                            },
                            {
                              "Key": "SowingRate",
                              "Value": "32"
                            },
                            {
                              "Key": "CultivarName",
                              "Value": "PioneerP932T16R_MG32"
                            },
                            {
                              "Key": "SowingDate",
                              "Value": "12/23/1997 00:00:00"
                            }
                          ],
                          "Name": "SowingRule",
                          "IncludeInDocumentation": true,
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Report, Models",
                          "VariableNames": [
                            "[Clock].Today",
                            "[Soybean].Structure.MainStemPrimordiaNo",
                            "[Soybean].Phenology.NFF",
                            "[Soybean].Script.FinalTag"
                          ],
                          "EventNames": [
                            "[Soybean].Harvesting"
                          ],
                          "GroupByVariableName": null,
                          "Name": "HarvestReport",
                          "Children": [],
