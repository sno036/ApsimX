                            },
                            {
                              "$type": "Models.Operations, Models",
                              "Operation": null,
                              "Name": "FertiliserSchedule",
                              "Children": [],
                              "IncludeInDocumentation": true,
                              "Enabled": true,
                              "ReadOnly": false
                            },
                            {
                              "$type": "Models.Manager, Models",
                              "Code": "\r\nusing System.Xml.Serialization;\r\nusing APSIM.Shared.Utilities;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\n        \r\nnamespace Models\r\n{\r\n    [Serializable] \r\n    [System.Xml.Serialization.XmlInclude(typeof(Model))]\r\n    public class Script : Model\r\n    {\r\n        [Link(ByName = true)] Plant FodderBeet;\r\n        [Link(ByName = true)] Plant Oats;\r\n        [Link] Clock Clock;\r\n\r\n        [Description(\"FodderBeet planting date: \")]\r\n        public DateTime FodderBeetPlantingDate { get; set; }\r\n        [Description(\"FodderBeet harvesting date: \")]\r\n        public DateTime FodderBeetHarvestingDate { get; set; }\r\n        [Description(\"Oats planting date: \")]\r\n        public DateTime OatsPlantingDate { get; set; }\r\n        [Description(\"Oats harvesting date 1: \")]\r\n        public DateTime OatsHarvestingDate1 { get; set; }\r\n        [Description(\"Oats harvesting date 2: \")]\r\n        public DateTime OatsHarvestingDate2 { get; set; }\r\n        \r\n        [XmlIgnore] public string CropSown { get; set; }\r\n        [XmlIgnore] public string CropAction { get; set; }\r\n\r\n        [XmlIgnore] public bool IrrgFactor { get; set; }\r\n        [XmlIgnore] public double FertFactor { get; set; }\r\n\r\n        private RemovalFractions removalFractions;\r\n        \r\n        [EventSubscribe(\"StartOfSimulation\")]\r\n        private void OnSimulationCommencing(object sender, EventArgs e)\r\n        {\r\n            CropSown = \"Fallow\";\r\n            CropAction = \"-\";\r\n\r\n            // set removal fractions for FodderBeet(these overrides the default removals in the plant)\r\n            removalFractions = new RemovalFractions();\r\n            removalFractions.SetFractionToRemove(\"Leaf\", 0.95, \"Live\");\r\n            removalFractions.SetFractionToResidue(\"Leaf\", 0.05, \"Live\");\r\n            removalFractions.SetFractionToRemove(\"Leaf\", 0.8, \"Dead\");\r\n            removalFractions.SetFractionToResidue(\"Leaf\", 0.2, \"Dead\");\r\n            removalFractions.SetFractionToRemove(\"Petiole\", 1.0, \"Live\");\r\n            removalFractions.SetFractionToResidue(\"Petiole\", 0.0, \"Live\");\r\n            removalFractions.SetFractionToRemove(\"Petiole\", 0.9, \"Dead\");\r\n            removalFractions.SetFractionToResidue(\"Petiole\", 0.1, \"Dead\");\r\n            removalFractions.SetFractionToRemove(\"StorageRoot\", 1.0, \"Live\");\r\n            removalFractions.SetFractionToResidue(\"StorageRoot\", 0.0, \"Live\");\r\n            removalFractions.SetFractionToRemove(\"StorageRoot\", 1.0, \"Dead\");\r\n            removalFractions.SetFractionToResidue(\"StorageRoot\", 0.0, \"Dead\");\r\n            //complement for oats\r\n            removalFractions.SetFractionToRemove(\"Stem\", 0.9, \"Live\");\r\n            removalFractions.SetFractionToResidue(\"Stem\", 0.1, \"Live\");\r\n            removalFractions.SetFractionToRemove(\"Stem\", 0.8, \"Dead\");\r\n            removalFractions.SetFractionToResidue(\"Stem\", 0.2, \"Dead\");\r\n            removalFractions.SetFractionToRemove(\"Panicle\", 0.9, \"Live\");\r\n            removalFractions.SetFractionToResidue(\"Panicle\", 0.1, \"Live\");\r\n            removalFractions.SetFractionToRemove(\"Panicle\", 0.8, \"Dead\");\r\n            removalFractions.SetFractionToResidue(\"Panicle\", 0.2, \"Dead\");\r\n            removalFractions.SetFractionToRemove(\"Grain\", 1.0, \"Live\");\r\n            removalFractions.SetFractionToResidue(\"Grain\", 0.0, \"Live\");\r\n            removalFractions.SetFractionToRemove(\"Grain\", 1.0, \"Dead\");\r\n            removalFractions.SetFractionToResidue(\"Grain\", 0.0, \"Dead\");\r\n\r\n        }\r\n        \r\n        [EventSubscribe(\"DoManagement\")]\r\n        private void OnDoManagement(object sender, EventArgs e)\r\n        {\r\n            CropAction = \"-\";\r\n\r\n            if (Clock.Today.Date == FodderBeetPlantingDate)\r\n            {\r\n                FodderBeet.Sow(population: 9, cultivar: \"Rivage\", depth: 5, rowSpacing: 500);\r\n                CropSown = \"FodderBeet\";\r\n                CropAction = \"Sowing\";\r\n            }\r\n            \r\n            if (Clock.Today.Date == OatsPlantingDate)\r\n            {\r\n                Oats.Sow(population: 400, cultivar: \"Milton\", depth: 45, rowSpacing: 45);\r\n                CropSown = \"Oats\";\r\n                CropAction = \"Sowing\";\r\n            }\r\n            \r\n            \r\n            if (Clock.Today.Date == FodderBeetHarvestingDate)\r\n            {\r\n                FodderBeet.Harvest(removalFractions);\r\n                //FodderBeet.EndCrop();\r\n                //CropSown = \"Fallow\";\r\n                CropAction = \"Harvesting\";\r\n            }\r\n            if (Clock.Today.Date == FodderBeetHarvestingDate.AddDays(1))\r\n            {\r\n                //FodderBeet.Harvest(removalFractions);\r\n                FodderBeet.EndCrop();\r\n                CropSown = \"Fallow\";\r\n            }\r\n\r\n            if (Clock.Today.Date == OatsHarvestingDate1)\r\n            {\r\n               if((FertFactor == 0) || ((IrrgFactor == false) && (FertFactor == 50)))\r\n               {\r\n                   Oats.Harvest(removalFractions);\r\n                   CropAction = \"Harvesting\";\r\n               }\r\n            }\r\n\r\n            if (Clock.Today.Date == OatsHarvestingDate2)\r\n            {\r\n               if((FertFactor == 300) || ((IrrgFactor == true) && (FertFactor == 50)))\r\n               {\r\n                   Oats.Harvest(removalFractions);\r\n                   CropAction = \"Harvesting\";\r\n               }\r\n            }\r\n\r\n            if (Clock.Today.Date == OatsHarvestingDate1.AddDays(1))\r\n            {\r\n               if((FertFactor == 0) || ((IrrgFactor == false) && (FertFactor == 50)))\r\n               {\r\n                   Oats.EndCrop();\r\n                   CropSown = \"Fallow\";\r\n               }\r\n            }\r\n\r\n            if (Clock.Today.Date == OatsHarvestingDate2.AddDays(1))\r\n            {\r\n               if((FertFactor == 300) || ((IrrgFactor == true) && (FertFactor == 50)))\r\n               {\r\n                   Oats.EndCrop();\r\n                   CropSown = \"Fallow\";\r\n               }\r\n            }\r\n        }\r\n        \r\n    }\r\n}\r\n",
                              "Parameters": [
                                {
                                  "Key": "FodderBeetPlantingDate",
                                  "Value": "10/18/2016 00:00:00"
                                },
                                {
                                  "Key": "FodderBeetHarvestingDate",
                                  "Value": "05/30/2017 00:00:00"
                                },
                                {
                                  "Key": "OatsPlantingDate",
                                  "Value": "07/05/2017 00:00:00"
                                },
                                {
                                  "Key": "OatsHarvestingDate1",
                                  "Value": "01/05/2018 00:00:00"
                                },
                                {
                                  "Key": "OatsHarvestingDate2",
                                  "Value": "01/10/2018 00:00:00"
                                }
                              ],
                              "Name": "CropOperations",
                              "IncludeInDocumentation": true,
                              "Enabled": true,
                              "ReadOnly": false
                            },
                            {
                              "$type": "Models.Manager, Models",
                              "Code": "using System.Xml.Serialization;\r\nusing Models;\r\nusing Models.PMF;\r\nusing System.Text;\r\nusing System.Collections.Generic;\r\nusing APSIM.Shared.Utilities;\r\nusing Models.Core;\r\nusing System;\r\n\r\n// This script simulates a rainshelter, it controls the amount of rainfall (=0.0) and radiation (=95% of weather)\r\n// It does that for a period between two dates, as well as at sporadic dates\r\n\r\nnamespace Models\r\n{\r\n    [Serializable] \r\n    [System.Xml.Serialization.XmlInclude(typeof(Model))]\r\n    public class Script : Model\r\n    {\r\n        [Link] Weather Met;\r\n        [Link] Clock Clock;\r\n    \r\n        [Description(\"Start date: \")]\r\n        public DateTime StartDate { get; set; }\r\n        [Description(\"End date: \")]\r\n        public DateTime EndDate { get; set; }\r\n         [Description(\"Other dates: \")]\r\n         public string OtherDateString  { get; set; }\r\n\r\n         [XmlIgnore] public string RainshelterCover  { get; set; }\r\n\r\n         private DateTime[] OtherDates;\r\n         private double todaysRain;\r\n\r\n        [EventSubscribe(\"StartOfSimulation\")]\r\n        private void OnSimulationCommencing(object sender, EventArgs e)\r\n        {\r\n            //gather the dates the variables will be controlled\r\n            string[] auxDates = OtherDateString.Split(new Char []{' ',','});\r\n            OtherDates = new DateTime[auxDates.Length];\r\n            for (int i = 0; i < auxDates.Length; i++)\r\n                OtherDates[i] = DateTime.Parse(auxDates[i]);\r\n\r\n            RainshelterCover = \"Off\";\r\n        }\r\n\r\n        [EventSubscribe(\"PreparingNewWeatherData\")]\r\n        private void OnPreparingNewWeatherData(object sender, EventArgs e)\r\n        {\r\n            RainshelterCover = \"Off\";\r\n\r\n            if ((Clock.Today.Date >= StartDate.Date) && (Clock.Today.Date <= EndDate.Date))\r\n            {\r\n                todaysRain = Met.Rain;\r\n                changeMetData();\r\n            }\r\n            else\r\n            {\r\n                for (int i = 0; i < OtherDates.Length; i++)\r\n                    if (Clock.Today.Date == OtherDates[0].Date)\r\n                        changeMetData();\r\n            }\r\n\r\n            // rain shelter partial day cover\r\n            if (Clock.Today.Date == DateTime.Parse(\"01/09/2017\").Date)\r\n                Met.Rain -= 2.0;\r\n            if (Clock.Today.Date == DateTime.Parse(\"08/11/2017\").Date)\r\n                Met.Rain -= 0.3;\r\n\r\n            // rain shelter cover removed for weekend\r\n            if ((Clock.Today.Date == DateTime.Parse(\"03/06/2017\").Date)||(Clock.Today.Date == DateTime.Parse(\"04/06/2017\").Date))\r\n            {\r\n                Met.Rain = todaysRain;\r\n                //Met.Radn /= 0.95;\r\n                RainshelterCover = \"Off\";\r\n            }\r\n        }\r\n\r\n        private void changeMetData()\r\n        {\r\n            Met.Rain *= 0.0;\r\n            //Met.Radn *= 0.95;\r\n            RainshelterCover = \"On\";\r\n        }\r\n    }\r\n}\r\n",
                              "Parameters": [
                                {
                                  "Key": "StartDate",
                                  "Value": "10/17/2016 00:00:00"
                                },
                                {
                                  "Key": "EndDate",
                                  "Value": "06/30/2017 00:00:00"
                                },
                                {
                                  "Key": "OtherDateString",
                                  "Value": "27/07/2017 28/07/2017 29/07/2017 30/07/2017 31/07/2017 08/08/2017 09/08/2017 10/08/2017 11/08/2017 12/08/2017 13/08/2017 14/08/2017 15/08/2017 16/08/2017 17/08/2017 18/08/2017 28/08/2017 29/08/2017 30/08/2017 31/08/2017"
                                }
                              ],
                              "Name": "ClimateControl",
                              "IncludeInDocumentation": true,
                              "Enabled": true,
                              "ReadOnly": false
                            },
                            {
                              "$type": "Models.Manager, Models",
                              "Code": "using APSIM.Shared.Utilities;\r\nusing System.Xml.Serialization;\r\nusing Models;\r\nusing Models.PMF;\r\nusing Models.Soils;\r\nusing System.Text;\r\nusing System.Collections.Generic;\r\nusing Models.Core;\r\nusing System;\r\n\r\n// This script performs management actions that are not common to all treatments\r\n\r\nnamespace Models\r\n{\r\n    [Serializable] \r\n    public class Script : Model\r\n    {\r\n        [Link] Clock Clock;\r\n        [Link] Irrigation Irrigation;\r\n        [Link] Fertiliser Fert;\r\n        [Link] Soil ThisSoil;\r\n\r\n        [Description(\"Allow irrigation to be applied?\")]\r\n        public bool IrrFactor { get; set; }\r\n        [Description(\"Amount of fertiliser to be applied (kg/ha)\")]\r\n        public double NitFactor { get; set; }\r\n\r\n        [EventSubscribe(\"StartOfSimulation\")]\r\n        private void OnSimulationCommencing(object sender, EventArgs e)\r\n        {\r\n            //    SetSoilLayers();\r\n        }\r\n        \r\n        [EventSubscribe(\"DoManagement\")]\r\n        private void OnDoManagement(object sender, EventArgs e)\r\n        {\r\n            // Fodderbeet - irrigation on high fert plots only\r\n            if ((IrrFactor == true) && (NitFactor == 300))\r\n            {\r\n                if (Clock.Today.Date == DateTime.Parse(\"01-Feb-2017\"))\r\n                    Irrigation.Apply(40.0);\r\n                if (Clock.Today.Date == DateTime.Parse(\"01-Mar-2017\"))\r\n                    Irrigation.Apply(32.6);\r\n            }\r\n        \r\n            // Oats - Irrigation on dryland plots only, after harvest\r\n            if (IrrFactor == false)\r\n            {\r\n                if ((Clock.Today.Date == DateTime.Parse(\"25-May-2017\")) || (Clock.Today.Date == DateTime.Parse(\"26-May-2017\")))\r\n                    Irrigation.Apply(50.0);\r\n\r\n                if (Clock.Today.Date == DateTime.Parse(\"29-May-2017\"))\r\n                if (NitFactor == 300)\r\n                    Irrigation.Apply(64.0);\r\n\r\n                if (Clock.Today.Date == DateTime.Parse(\"30-May-2017\"))\r\n                {\r\n                    if (NitFactor == 0)\r\n                        Irrigation.Apply(30.3);\r\n                    if (NitFactor == 50)\r\n                        Irrigation.Apply(51.0);\r\n                }\r\n            }\r\n\r\n            // Oats - Irrigation on all 300N plots plus dryland 50N plots\r\n            if (Clock.Today.Date == DateTime.Parse(\"13-Dec-2017\"))\r\n            {\r\n                if (NitFactor == 300)\r\n                    Irrigation.Apply(50.0);\r\n                if ((NitFactor == 50) && (IrrFactor == false))\r\n                    Irrigation.Apply(50.0);\r\n            }\r\n\r\n            // Oats - Fertiliser for irrigated plots only, on sowing\r\n            if (Clock.Today.Date == DateTime.Parse(\"05-Jul-2017\"))\r\n            if (IrrFactor == true)\r\n            {\r\n                if (NitFactor == 0)\r\n                    Fert.Apply(40, Models.Fertiliser.Types.UreaN, 10);\r\n                if (NitFactor == 50)\r\n                    Fert.Apply(85, Models.Fertiliser.Types.UreaN, 10);\r\n                if (NitFactor == 300)\r\n                    Fert.Apply(270, Models.Fertiliser.Types.UreaN, 10);\r\n            }\r\n        }\r\n    }\r\n}\r\n",
                              "Parameters": [
                                {
                                  "Key": "IrrFactor",
                                  "Value": "False"
                                },
                                {
                                  "Key": "NitFactor",
                                  "Value": "0"
                                }
                              ],
                              "Name": "AdditionalActions",
                              "IncludeInDocumentation": true,
                              "Enabled": true,
                              "ReadOnly": false
                            }
                          ],
                          "IncludeInDocumentation": true,
                          "Enabled": true,
                          "ReadOnly": false
                        },
