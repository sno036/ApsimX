                        {
                          "$type": "Models.Report, Models",
                          "VariableNames": [
                            "[Clock].Today",
                            "[Soil].SoilWater.SW[4] as SW15cm",
                            "([Soil].SoilWater.SW[6]+[Soil].SoilWater.SW[7])/2 as SW45cm",
                            "[Soil].Temperature[4] as ST15cm",
                            "([Soil].Temperature[6]+[Soil].Temperature[7])/2 as ST45cm"
                          ],
                          "EventNames": [
                            "[Clock].DoReport"
                          ],
                          "GroupByVariableName": null,
                          "Name": "FACTSReport",
                          "Children": [],
                          "IncludeInDocumentation": true,
                          "Enabled": true,
                          "ReadOnly": false
                        },
                        {
                          "$type": "Models.Manager, Models",
                          "Code": "\r\nusing Models.Soils.Nutrients;\r\nusing Models.Soils;\r\nusing APSIM.Shared.Utilities;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\n        \r\n        namespace Models\r\n        {\r\n           [Serializable] \r\n           [System.Xml.Serialization.XmlInclude(typeof(Model))]\r\n            public class Script : Model\r\n            {      \r\n               [Link] Soil Soil;\r\n               [Link] Clock Clock;\r\n\r\n               [Description(\"Initial Water Table Depth (mm)\")]\r\n               public double InitialWaterTableDepth { get; set; }\r\n\r\n              [Description(\"InSeason Table Depth (mm)\")]\r\n               public double InSeasonWaterTableDepth { get; set; }\r\n\r\n               [Description(\"Start Date\")]\r\n               public DateTime StartDate { get; set; }\r\n\r\n               [Description(\"End Date\")]\r\n               public DateTime EndDate { get; set; }\r\n\r\n\r\n        [EventSubscribe(\"StartOfSimulation\")]\r\n        private void OnSimulationCommencing(object sender, EventArgs e)\r\n        {\r\n        //(Soil.SoilWater).WaterTable = InitialWaterTableDepth;\r\n        }       \r\n\r\n               [EventSubscribe(\"DoManagement\")]\r\n               private void OnDoManagement(object sender, EventArgs e)\r\n               {\r\n                if (Clock.Today.Date >= StartDate && Clock.Today.Date >= EndDate)\r\n                   (Soil.SoilWater).WaterTable = InSeasonWaterTableDepth;\r\n                else\r\n                    (Soil.SoilWater).WaterTable = InitialWaterTableDepth;\r\n               }\r\n            }\r\n        }\r\n                \r\n",
                          "Parameters": [
                            {
                              "Key": "InitialWaterTableDepth",
                              "Value": "2000"
                            },
                            {
                              "Key": "InSeasonWaterTableDepth",
                              "Value": "1000"
                            },
                            {
                              "Key": "StartDate",
                              "Value": "05/01/2017 00:00:00"
                            },
                            {
                              "Key": "EndDate",
                              "Value": "05/20/2017 00:00:00"
                            }
                          ],
                          "Name": "WaterTableManager",
                          "IncludeInDocumentation": true,
                          "Enabled": true,
                          "ReadOnly": false
                        },
